# Jira connection
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_AUTH_TYPE=basic  # "basic" (Jira Cloud) or "bearer" (Jira Data Center PAT)

# Knowledge store: "sqlite" (default, local file) or "pgvector" (Postgres + pgvector)
# KNOWLEDGE_STORE=sqlite  # default; uncomment only to switch to "pgvector"
SQLITE_PATH=~/.mcp-issues/knowledge.db

# Only needed when KNOWLEDGE_STORE=pgvector
# DATABASE_URL=postgres://mcp:mcp@localhost:15432/mcp

# Embedder: "voyage" (default) or "openai" or "onnx"
RAG_EMBEDDER=voyage
VOYAGE_API_KEY=your-voyage-api-key
# OPENAI_API_KEY=your-openai-api-key
# ONNX_MODEL_PATH=/path/to/model/dir
# ONNX_LIB_DIR=/path/to/onnxruntime/lib

# HTTP transport only
# MCP_API_KEY=your-secret-key
# MCP_ADDR=:8080
